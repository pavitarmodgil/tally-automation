# Copy this file to .env and fill in your values
# Never commit .env — only .env.example goes to git

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tally-automation

# ── Express ──────────────────────────────────────────────────────────────────
PORT=5000

# ── Admin authentication ─────────────────────────────────────────────────────
# Generate the hash ONCE and paste it here (never store the plaintext password):
#   node -e "require('bcrypt').hash('your-password-here', 10).then(console.log)"
ADMIN_PASSWORD_HASH=

# Random secret for signing JWTs — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used by CORS, WhatsApp order links, and ngrok tunnel.
# Update every time ngrok restarts. No trailing slash. No leading spaces.
FRONTEND_URL=https://YOUR-NGROK-URL.ngrok-free.app

# ── Tally ─────────────────────────────────────────────────────────────────────
# Tally HTTP server URL (enable via F12 → Advanced Config → ODBC/HTTP → port 9000)
TALLY_URL=http://localhost:9000

# Fixed voucher date for TallyPrime EDU.
# EDU only accepts dates inside the active financial year (e.g. Apr 2025 – Mar 2026).
# Remove or update when moving to a licensed version.
TALLY_DATE=2025-04-01
