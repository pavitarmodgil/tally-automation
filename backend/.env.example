# Copy this file to .env and fill in your values
# Never commit .env — only .env.example goes to git

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tally-automation

# Express server port
PORT=5000

# Twilio credentials (from Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public ngrok URL (update every time ngrok restarts)
# Used to send order links to customers via WhatsApp
FRONTEND_URL=https://YOUR-NGROK-URL.ngrok-free.app

# Tally HTTP server URL (default: localhost:9000)
TALLY_URL=http://localhost:9000

# Fixed voucher date for TallyPrime EDU
# EDU version only accepts dates within its active financial year.
# Keep this set to a date inside Apr 2025 – Mar 2026.
# Remove or update this when moving to a licensed Tally version.
TALLY_DATE=2025-04-01
